# ============================================================================
#  ProAIcademy environment variables
#  Copy this file to ".env" and fill in your values:  cp .env.example .env
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
#  FRONTEND (PUBLIC — safe to expose in the browser)
#  Consumed by `npm run build` to generate proai-env.js.
# ─────────────────────────────────────────────────────────────────────────

# Your Supabase project URL and publishable (anon) key.
SUPABASE_URL=https://yiwgyovzohcwvqpwmesk.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_OMCnXrtMw-Dya2a1Z3g7HA_2GUzR0lb

# Midtrans CLIENT key (browser-safe). Leave empty to keep checkout disabled.
# Sandbox looks like  SB-Mid-client-xxxxxxxx ; production like  Mid-client-xxxxxxxx
MIDTRANS_CLIENT_KEY=

# false = Midtrans sandbox, true = production. Used by both the browser and the
# create-payment Edge Function — keep them in sync.
MIDTRANS_IS_PRODUCTION=false

# ─────────────────────────────────────────────────────────────────────────
#  LOCAL STATIC SERVER
# ─────────────────────────────────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────────────────
#  SUPABASE EDGE FUNCTION SECRETS (SERVER-SIDE — NEVER expose in the browser)
#  These are NOT read by the frontend. Set them on the project with:
#     supabase secrets set --env-file ./supabase/functions/.env
#  (or paste them in Dashboard → Edge Functions → Secrets)
#  SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY are provided to
#  functions automatically — do not set them yourself.
# ─────────────────────────────────────────────────────────────────────────
# MIDTRANS_SERVER_KEY=your-midtrans-server-key
