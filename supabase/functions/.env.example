# Supabase Edge Function secrets (SERVER-SIDE — keep secret, never commit the real file).
# Copy to ./supabase/functions/.env and push to your project with:
#     supabase secrets set --env-file ./supabase/functions/.env
#
# Note: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY and SUPABASE_ANON_KEY are injected
# into Edge Functions automatically by Supabase — do NOT set them here.

# Midtrans SERVER key (secret). Sandbox: SB-Mid-server-xxxx ; production: Mid-server-xxxx
MIDTRANS_SERVER_KEY=

# false = Midtrans sandbox, true = production (keep in sync with the frontend value).
MIDTRANS_IS_PRODUCTION=false
